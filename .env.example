# Copiar a ".env" en la raíz del repo y ajustar valores antes de "docker compose up".

# --- Django ---
# Generar uno nuevo para producción, no reusar el default de desarrollo:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
FRONTEND_URL=http://localhost

# --- Email (invitaciones de usuarios) ---
# Por defecto no se envía nada, solo se imprime en consola/logs del backend.
# Para enviar de verdad vía Resend (https://resend.com, free tier 3000/mes),
# descomentar y usar la API key como password SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=true
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=re_xxxxxxxx
# DEFAULT_FROM_EMAIL=onboarding@resend.dev

# --- Postgres (usados por el servicio "db" y armados en DATABASE_URL por docker-compose) ---
POSTGRES_DB=aztools
POSTGRES_USER=aztools
POSTGRES_PASSWORD=change-me-in-production

# --- Puertos ---
HTTP_PORT=80
